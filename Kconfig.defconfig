if KNX_IOT_ADD_ON

# Route SPAKE2+ through PSA Crypto (NCS/Oberon) instead of libknx's bundled
# mbedTLS path. Upstream defaults are MBEDTLS=y / PSA=n; flip both.
config KNXIOT_SPAKE2P_PSA
	default y

config KNXIOT_SPAKE2P_MBEDTLS
	default n

config KNXIOT_LIB_DEMO_APPS
	default n

endif # KNX_IOT_ADD_ON
